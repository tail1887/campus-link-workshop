generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum RecruitCategory {
  study
  project
  hackathon
}

enum Role {
  student
  admin
}

enum OnboardingStatus {
  not_started
  in_progress
  completed
}

enum OnboardingStep {
  account
  interests
  profile
  complete
}

enum CollaborationStyle {
  async_first
  hybrid
  live_sprint
  flexible
}

enum WeeklyHoursBand {
  under_3
  three_to_six
  six_to_ten
  ten_plus
  flexible
}

enum ExternalLinkType {
  portfolio
  github
  linkedin
  blog
  other
}

enum ResumeVisibility {
  private
  shared
}

enum VerificationStatus {
  unverified
  pending
  verified
  rejected
}

enum VerificationBadge {
  none
  pending
  verified
}

enum VerificationMethod {
  campus_email
  student_card
  manual_review
}

enum InquiryCategory {
  general
  account
  verification
  resume
  report
}

enum InquiryStatus {
  open
  in_review
  resolved
}

enum AlertDigestFrequency {
  off
  daily
  weekly
}

enum ApplicationStatus {
  pending
  reviewed
  accepted
  rejected
}

model User {
  id              String            @id @default(cuid())
  email           String            @unique
  passwordHash    String
  displayName     String
  campus          String?
  role            Role              @default(student)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  sessions        Session[]
  onboardingState OnboardingState?
  profile         Profile?
  resume          Resume?
  verification    Verification?
  inquiries       Inquiry[]
  alertPreference AlertPreference?
  recruitPosts    RecruitPost[]
  applications    RecruitApplication[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model OnboardingState {
  userId           String           @id
  status           OnboardingStatus @default(not_started)
  currentStep      OnboardingStep   @default(account)
  interestKeywords String[]
  completedAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Profile {
  userId              String              @id
  headline            String
  intro               String
  collaborationStyle  CollaborationStyle?
  weeklyHours         WeeklyHoursBand?
  contactEmail        String?
  openToRoles         String[]
  links               Json
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Resume {
  userId      String           @id
  title       String
  summary     String
  skills      String[]
  education   String
  experience  Json
  projects    Json
  links       Json
  visibility  ResumeVisibility @default(private)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  userId           String             @id
  status           VerificationStatus @default(unverified)
  badge            VerificationBadge  @default(none)
  method           VerificationMethod?
  evidenceLabel    String?
  evidenceUrl      String?
  note             String?
  submittedAt      DateTime?
  reviewedAt       DateTime?
  verifiedAt       DateTime?
  rejectionReason  String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Inquiry {
  id                 String          @id @default(cuid())
  userId             String
  category           InquiryCategory
  subject            String
  message            String
  contactEmail       String
  status             InquiryStatus   @default(open)
  resolutionSummary  String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  resolvedAt         DateTime?
  user               User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model AlertPreference {
  userId               String               @id
  emailEnabled         Boolean              @default(true)
  inAppEnabled         Boolean              @default(true)
  applicationUpdates   Boolean              @default(true)
  verificationUpdates  Boolean              @default(true)
  inquiryReplies       Boolean              @default(true)
  marketingEnabled     Boolean              @default(false)
  digestFrequency      AlertDigestFrequency @default(weekly)
  quietHoursStart      String?
  quietHoursEnd        String?
  quietHoursTimezone   String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  user                 User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RecruitPost {
  id             String               @id @default(cuid())
  slug           String               @unique
  title          String
  category       RecruitCategory
  campus         String
  summary        String
  description    String
  roles          String[]
  techStack      String[]
  capacity       Int
  currentMembers Int                  @default(2)
  stage          String
  deadline       DateTime
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  highlight      Boolean              @default(true)
  ownerName      String
  ownerRole      String
  meetingStyle   String
  schedule       String
  goal           String
  expectations   String[]
  perks          String[]
  ownerId        String?
  owner          User?                @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  applications   RecruitApplication[]

  @@index([category, deadline])
}

model RecruitApplication {
  id          String            @id @default(cuid())
  postId      String
  applicantId String?
  name        String
  contact     String
  message     String
  status      ApplicationStatus @default(pending)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  applicant   User?             @relation(fields: [applicantId], references: [id], onDelete: SetNull)
  post        RecruitPost       @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, contact])
  @@index([createdAt])
}
