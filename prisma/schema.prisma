generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum RecruitCategory {
  study
  project
  hackathon
}

enum Role {
  student
  admin
}

enum OnboardingStatus {
  not_started
  in_progress
  completed
}

enum OnboardingStep {
  account
  interests
  profile
  complete
}

enum ApplicationStatus {
  pending
  reviewed
  accepted
  rejected
}

model User {
  id              String            @id @default(cuid())
  email           String            @unique
  passwordHash    String
  displayName     String
  campus          String?
  role            Role              @default(student)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  sessions        Session[]
  onboardingState OnboardingState?
  recruitPosts    RecruitPost[]
  applications    RecruitApplication[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model OnboardingState {
  userId           String           @id
  status           OnboardingStatus @default(not_started)
  currentStep      OnboardingStep   @default(account)
  interestKeywords String[]
  completedAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RecruitPost {
  id             String               @id @default(cuid())
  slug           String               @unique
  title          String
  category       RecruitCategory
  campus         String
  summary        String
  description    String
  roles          String[]
  techStack      String[]
  capacity       Int
  currentMembers Int                  @default(2)
  stage          String
  deadline       DateTime
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  highlight      Boolean              @default(true)
  ownerName      String
  ownerRole      String
  meetingStyle   String
  schedule       String
  goal           String
  expectations   String[]
  perks          String[]
  ownerId        String?
  owner          User?                @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  applications   RecruitApplication[]

  @@index([category, deadline])
}

model RecruitApplication {
  id          String            @id @default(cuid())
  postId      String
  applicantId String?
  name        String
  contact     String
  message     String
  status      ApplicationStatus @default(pending)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  applicant   User?             @relation(fields: [applicantId], references: [id], onDelete: SetNull)
  post        RecruitPost       @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, contact])
  @@index([createdAt])
}
